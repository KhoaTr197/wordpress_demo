    "border": {
      "customRadius": true
    },
    "custom": {
      "radius-none": "0",
      "radius": "0.65rem",
      "radius-sm": "calc(var(--wp--custom--radius) - 4px)",
      "radius-md": "calc(var(--wp--custom--radius) - 2px)",
      "radius-lg": "var(--wp--custom--radius)",
      "radius-xl": "calc(var(--wp--custom--radius) + 4px)",
      "radius-full": "9999px"
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1200px"
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "size": "clamp(10px, 2vw, 20px)",
          "slug": "xs",
          "name": "XSmall"
        },
        {
          "size": "clamp(20px, 4vw, 40px)",
          "slug": "sm",
          "name": "Small"
        },
        {
          "size": "clamp(30px, 6vw, 60px)",
          "slug": "md",
          "name": "Medium"
        },
        {
          "size": "clamp(40px, 8vw, 80px)",
          "slug": "lg",
          "name": "Large"
        },
        {
          "size": "clamp(50px, 10vw, 100px)",
          "slug": "xl",
          "name": "Xlarge"
        },
        {
          "size": "clamp(60px, 12vw, 120px)",
          "slug": "xxl",
          "name": "XXlarge"
        }
      ],
      "units": [
        "%",
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "fluid": true,
      "fontSizes": [
        {
          "name": "Extra Small",
          "slug": "text-xs",
          "size": "0.75rem",
          "fluid": false
        },
        {
          "name": "Small",
          "slug": "text-sm",
          "size": "0.875rem",
          "fluid": {
            "min": "0.75rem",
            "max": "0.875rem"
          }
        },
        {
          "name": "Base",
          "slug": "text-base",
          "size": "1rem",
          "fluid": {
            "min": "0.825rem",
            "max": "1rem"
          }
        },
        {
          "name": "Large",
          "slug": "text-lg",
          "size": "1.125rem",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "name": "Extra Large",
          "slug": "text-xl",
          "size": "1.25rem",
          "fluid": {
            "min": "1.125rem",
            "max": "1.25rem"
          }
        },
        {
          "name": "2XL",
          "slug": "text-2xl",
          "size": "1.5rem",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "name": "3XL",
          "slug": "text-3xl",
          "size": "1.875rem",
          "fluid": {
            "min": "1.5rem",
            "max": "1.875rem"
          }
        },
        {
          "name": "4XL",
          "slug": "text-4xl",
          "size": "2.25rem",
          "fluid": {
            "min": "1.875rem",
            "max": "2.25rem"
          }
        },
        {
          "name": "5XL",
          "slug": "text-5xl",
          "size": "3rem",
          "fluid": {
            "min": "2.25rem",
            "max": "3rem"
          }
        },
        {
          "name": "6XL",
          "slug": "text-6xl",
          "size": "3.75rem",
          "fluid": {
            "min": "3rem",
            "max": "3.75rem"
          }
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "blocks": {
      "core/button": {
        "border": {
          "color": "var(--wp--preset--color--border)",
          "style": "solid",
          "width": "1px",
          "radius": "var(--wp--custom--radius-full)"
        },
        "spacing": {
          "padding": "0.5rem 1rem"
        },
        "variations": {
          "primary": {
            "color": {
              "background": "var(--wp--preset--color--primary)",
              "text": "var(--wp--preset--color--primary-foreground)"
            }
          },
          "outline": {
            "color": {
              "background": "var(--wp--preset--color--background)",
              "text": "var(--wp--preset--color--foreground)"
            }
          }
        }
      }
    },
    "elements": {
      "button": {
        "typography": {
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--primary-foreground)"
        },
        ":focus": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--white)"
          }
        },
        ":active": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--white)"
          }
        },
        ":hover": {
          "css": "&:hover { transform: translateY(0.5rem); }"
        },
        ":visited": {
          "color": {
            "text": "var(--wp--preset--color--white)"
          }
        }
      }
    }
  }
}