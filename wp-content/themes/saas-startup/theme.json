    "border": {
      "customRadius": true
    },
    "custom": {
      "radius-none": "0",
      "radius": "0.65rem",
      "radius-sm": "calc(var(--wp--custom--radius) - 4px)",
      "radius-md": "calc(var(--wp--custom--radius) - 2px)",
      "radius-lg": "var(--wp--custom--radius)",
      "radius-xl": "calc(var(--wp--custom--radius) + 4px)",
      "radius-full": "9999px"
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1200px"
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "size": "clamp(5px, 1vw, 10px)",
          "slug": "superbspacing-xxsmall",
          "name": "XXSmall"
        },
        {
          "size": "clamp(10px, 2vw, 20px)",
          "slug": "superbspacing-xsmall",
          "name": "XSmall"
        },
        {
          "size": "clamp(20px, 4vw, 40px)",
          "slug": "superbspacing-small",
          "name": "Small"
        },
        {
          "size": "clamp(30px, 6vw, 60px)",
          "slug": "superbspacing-medium",
          "name": "Medium"
        },
        {
          "size": "clamp(40px, 8vw, 80px)",
          "slug": "superbspacing-large",
          "name": "Large"
        },
        {
          "size": "clamp(50px, 10vw, 100px)",
          "slug": "superbspacing-xlarge",
          "name": "Xlarge"
        },
        {
          "size": "clamp(60px, 12vw, 120px)",
          "slug": "superbspacing-xxlarge",
          "name": "XXlarge"
        }
      ],
      "units": [
        "%",
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontSizes": [
